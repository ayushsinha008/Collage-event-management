{
  "openapi": "3.0.0",
  "info": {
    "title": "FestFlow API",
    "description": "API documentation for the FestFlow College Event Management Platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Local server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get current user profile",
        "responses": {
          "200": {
            "description": "Profile data"
          }
        }
      }
    },
    "/events": {
      "get": {
        "summary": "Get all events",
        "responses": {
          "200": {
            "description": "List of events"
          }
        }
      }
    }
  }
}
